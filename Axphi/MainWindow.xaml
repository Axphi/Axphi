<Window
    x:Class="Axphi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:comp="clr-namespace:Axphi.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Axphi"
    xmlns:mainWinComp="clr-namespace:Axphi.WindowsComponents.MainWindow"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ws="https://schemas.elecho.dev/wpfsuite"
    Title="MainWindow"
    Width="1200"
    Height="650"
    d:DataContext="{d:DesignInstance Type=local:MainWindow,
                                     IsDesignTimeCreatable=False}"
    ws:WindowOption.IsCaptionMenuVisible="False"
    Background="#1f1f1f"
    Foreground="#d6d6d6"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ModernScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#555555" CornerRadius="0" Margin="2,0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#888888"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="MinWidth" Value="0"/>
                    <Setter Property="Width" Value="8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track" IsDirectionReversed="true">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ModernScrollThumb}"/>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="{TemplateBinding Background}">
                                    <Track x:Name="PART_Track" IsDirectionReversed="False">
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ModernScrollThumb}">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border x:Name="ThumbBorder" Background="#555555" CornerRadius="3" Margin="0,2"/>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ThumbBorder" Property="Background" Value="#888888"/>
                                                            </Trigger>
                                                            <Trigger Property="IsDragging" Value="True">
                                                                <Setter TargetName="ThumbBorder" Property="Background" Value="#AAAAAA"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    

    <ws:WindowContentAdapter>
        <DockPanel>
            <mainWinComp:TitleBar DockPanel.Dock="Top" />
            <Grid Margin="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="2.8*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <comp:TabPane
                    Grid.Row="0"
                    Grid.Column="0"
                    Header="Flow">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <comp:BezierCurveEditor
                                X1="{Binding BezierViewModel.X1, Mode=TwoWay}"
                                X2="{Binding BezierViewModel.X2, Mode=TwoWay}"
                                Y1="{Binding BezierViewModel.Y1, Mode=TwoWay}"
                                Y2="{Binding BezierViewModel.Y2, Mode=TwoWay}" />
                            <StackPanel
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.X1}" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.Y1}" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.X2}" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.Y2}" />
                            </StackPanel>
                        </StackPanel>

                    </Grid>
                </comp:TabPane>

                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="2.8*" />
                    </Grid.ColumnDefinitions>

                    <comp:TabPane Grid.Column="0">
                        <comp:TabPane.Header>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Line" VerticalAlignment="Center" />
                                <ws:Button Content="+" Margin="10,0,0,0" Padding="8,0" Command="{Binding Timeline.AddJudgementLineCommand}" ToolTip="添加图层"/>
                            </StackPanel>
                        </comp:TabPane.Header>
                    </comp:TabPane>

                    <comp:TabPane Grid.Column="1" Header="Timeline">
                    </comp:TabPane>

                    <ScrollViewer Grid.Column="0" Grid.ColumnSpan="2" Margin="2,35,2,2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Hidden">

                        <ItemsControl ItemsSource="{Binding Timeline.CurrentChart.JudgementLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="2.8*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Margin="0,0,2,2" Background="#2d2d2d" BorderBrush="#444" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <Grid Height="20" Background="Transparent">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="4" />
                                                        <ColumnDefinition Width="20" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Rectangle Grid.Column="0" Fill="#FFD700" />
                                                    <ToggleButton x:Name="ExpandButton" Grid.Column="1" Cursor="Hand">
                                                        <ToggleButton.Template>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <TextBlock x:Name="ArrowText" Text="&gt;" Foreground="#d6d6d6" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" FontWeight="Bold"/>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsChecked" Value="True">
                                                                        <Setter TargetName="ArrowText" Property="Text" Value="v" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="ArrowText" Property="Foreground" Value="#FFD700" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </ToggleButton.Template>
                                                    </ToggleButton>
                                                    <TextBlock Grid.Column="2" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="#d6d6d6" Text="判定线图层" />
                                                </Grid>

                                                <StackPanel Visibility="{Binding IsChecked, ElementName=ExpandButton, Converter={StaticResource BoolToVis}}" Margin="24,0,0,0" Background="#252525">
                                                    <Grid Height="20">
                                                        <TextBlock Text="Offset (位移)" Foreground="#aaa" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="11"/>
                                                    </Grid>
                                                    <Grid Height="20">
                                                        <TextBlock Text="Scale (缩放)" Foreground="#aaa" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="11"/>
                                                    </Grid>
                                                    <Grid Height="20">
                                                        <TextBlock Text="Rotation (旋转)" Foreground="#aaa" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="11"/>
                                                    </Grid>
                                                    <Grid Height="20">
                                                        <TextBlock Text="Opacity (透明度)" Foreground="#aaa" VerticalAlignment="Center" Margin="5,0,0,0" FontSize="11"/>
                                                    </Grid>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Margin="0,0,0,2" Background="#1e1e1e" BorderBrush="#444" BorderThickness="0,0,0,1">
                                            <StackPanel>
                                                <Grid Height="20" Background="#252525">
                                                    
                                                </Grid>

                                                <StackPanel Visibility="{Binding IsChecked, ElementName=ExpandButton, Converter={StaticResource BoolToVis}}">
                                                    <Border Height="20" BorderBrush="#333" BorderThickness="0,1,0,0"/>
                                                    <Border Height="20" BorderBrush="#333" BorderThickness="0,1,0,0"/>
                                                    <Border Height="20" BorderBrush="#333" BorderThickness="0,1,0,0"/>
                                                    <Border Height="20" BorderBrush="#333" BorderThickness="0,1,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                
                <comp:TabPane
                    Grid.Row="1"
                    Grid.Column="2"
                    Header="Project">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ws:Button Command="{Binding FileActions.ImportMusicCommand}" Content="Import" />
                        </StackPanel>
                    </StackPanel>
                </comp:TabPane>

                <DockPanel Grid.Row="0" Grid.Column="1">

                    <mainWinComp:ChartDisplay x:Name="MainChartDisplay" />

                </DockPanel>
            </Grid>
        </DockPanel>
    </ws:WindowContentAdapter>
</Window>
