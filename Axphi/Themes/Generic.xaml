<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:comp="clr-namespace:Axphi.Components"
    xmlns:data="clr-namespace:Axphi.Data"
    xmlns:ws="https://schemas.elecho.dev/wpfsuite"
    xmlns:nodify="https://miroiu.github.io/nodify"
    xmlns:services="clr-namespace:Axphi.Services"
    xmlns:vms="clr-namespace:Axphi.ViewModels"
    xmlns:v="clr-namespace:Axphi.Views">


    <DataTemplate DataType="{x:Type vms:TimeLineJudgmentLineViewModel}">
        <Border Background="#2B579A"
                BorderBrush="#4B86D9"
                BorderThickness="1"
                CornerRadius="2"
                Height="{Binding Height, Mode=OneWay}"
                Width="{Binding Width, Mode=OneWay}"></Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vms:TimeLineKeyFrameViewModel}">
        <comp:KeyFrame />
    </DataTemplate>



    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!--  右箭头模板  -->
    <DataTemplate x:Key="ArrowRightTemplate">
        <Path Data="M 0 0 L 2 2 L 0 4"
              Stroke="#D1D1D1"
              StrokeThickness="1"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
              Fill="Transparent"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="10" Height="10" Stretch="Uniform" />
    </DataTemplate>

    <!--  下箭头模板  -->
    <DataTemplate x:Key="ArrowDownTemplate">
        <Path Data="M 0 0 L 2 2 L 4 0"
              Stroke="#D1D1D1"
              StrokeThickness="1"
              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
              Fill="Transparent"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="10" Height="10" Stretch="Uniform" />
    </DataTemplate>



    <Style TargetType="{x:Type comp:TabPane}">
        <Setter Property="Background" Value="#1f1f1f" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type comp:TabPane}">
                    <Border Background="#3d3d3d"
                            BorderBrush="#3d3d3d"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="24" />
                                <RowDefinition Height="1*" />
                            </Grid.RowDefinitions>

                            <ContentPresenter Grid.Row="0"
                                              Margin="2"
                                              ContentSource="Header"
                                              TextBlock.Foreground="#eeeeee"
                                              VerticalAlignment="Center" />
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter />
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <Style x:Key="ModernScrollThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border
                    x:Name="ThumbBorder"
                    Margin="2,0"
                    Background="#555555"
                    CornerRadius="0" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#888888" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#AAAAAA" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Width" Value="8" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{TemplateBinding Background}">
                                <Track x:Name="PART_Track" IsDirectionReversed="true">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ModernScrollThumb}" />
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>

            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Height" Value="8" />

                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{TemplateBinding Background}">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ModernScrollThumb}">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border
                                                    x:Name="ThumbBorder"
                                                    Margin="0,2"
                                                    Background="#555555"
                                                    CornerRadius="0" />
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="ThumbBorder" Property="Background" Value="#888888" />
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="ThumbBorder" Property="Background" Value="#AAAAAA" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>


    <SolidColorBrush x:Key="SplitterLineBrush" Color="#5A6C82" />
    <SolidColorBrush x:Key="SplitterLineHoverBrush" Color="#7F9FC2" />
    <SolidColorBrush x:Key="SplitterLineDragBrush" Color="#A9D0FF" />

    <Style x:Key="ThinVerticalSplitterStyle" TargetType="GridSplitter">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridSplitter">
                    <Grid Background="Transparent">
                        <Rectangle x:Name="Line"
                                   Width="1"
                                   HorizontalAlignment="Center"
                                   Fill="{StaticResource SplitterLineBrush}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Line" Property="Fill" Value="{StaticResource SplitterLineHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Line" Property="Fill" Value="{StaticResource SplitterLineHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Line" Property="Fill" Value="{StaticResource SplitterLineDragBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type comp:TrackHeaderJudgementLine}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type comp:TrackHeaderJudgementLine}">
                    <Grid Background="#4A4A4A"
                          Height="Auto"
                          HorizontalAlignment="Stretch"
                          FocusVisualStyle="{x:Null}">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="{x:Static services:TrackLayoutService.BaseTrackGridHeight}" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>


                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="100" />

                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Rectangle Grid.Column="0"
                                   Grid.Row="0"
                                   Width="5"
                                   Height="20"
                                   Fill="#feffa9" />

                        <ToggleButton
                            Grid.Column="1"
                            Grid.Row="0"
                            Width="20" Height="20"
                            IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                            Background="Transparent"
                            FocusVisualStyle="{x:Null}">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="ContentTemplate" Value="{StaticResource ArrowRightTemplate}" />

                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="0">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="ContentTemplate" Value="{StaticResource ArrowDownTemplate}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>
                        <TextBox
                            Grid.Column="2"
                            Grid.Row="0"
                            Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            Margin="2,0,5,0"
                            Padding="0">
                            <TextBox.Style>
                                <Style TargetType="TextBox">

                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="#eeeeee" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="CaretBrush" Value="#eeeeee" />

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#636363" />
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="Background" Value="#E8E8E8" />
                                            <Setter Property="Foreground" Value="#000000" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="CaretBrush" Value="#000000" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>


                        <StackPanel Grid.Row="1" Grid.ColumnSpan="4" Background="#333333">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <comp:TrackHeaderProperty Header="Position"
                                                      Visibility="{Binding IsPositionVisible, Converter={StaticResource BoolToVis}}"
                                                      AddKeyframeCommand="{Binding DataContext.AddKeyframeCommand, RelativeSource={RelativeSource AncestorType=comp:TrackHeader}}"
                                                      CommandParameter="Position">
                                <StackPanel Orientation="Horizontal">
                                    <comp:DraggableValueBox DragSpeed="0.1" NumberFormat="0.00"
                                                            Value="{Binding PositionVM.X, Mode=TwoWay}" />
                                    <TextBlock Text=", " Foreground="#888" VerticalAlignment="Center" />
                                    <comp:DraggableValueBox DragSpeed="0.1" NumberFormat="0.00"
                                                            Value="{Binding PositionVM.Y, Mode=TwoWay}" />
                                </StackPanel>
                            </comp:TrackHeaderProperty>

                            <comp:TrackHeaderProperty Header="Scale"
                                                      Visibility="{Binding IsScaleVisible, Converter={StaticResource BoolToVis}}"
                                                      AddKeyframeCommand="{Binding DataContext.AddKeyframeCommand, RelativeSource={RelativeSource AncestorType=comp:TrackHeader}}"
                                                      CommandParameter="Scale">
                                <StackPanel Orientation="Horizontal">
                                    <comp:DraggableValueBox DragSpeed="0.01" NumberFormat="0.00"
                                                            Value="{Binding ScaleVM.X, Mode=TwoWay}" />
                                    <TextBlock Text=", " Foreground="#888" VerticalAlignment="Center" />
                                    <comp:DraggableValueBox DragSpeed="0.01" NumberFormat="0.00"
                                                            Value="{Binding ScaleVM.Y, Mode=TwoWay}" />
                                </StackPanel>
                            </comp:TrackHeaderProperty>

                            <comp:TrackHeaderProperty Header="Rotation"
                                                      Visibility="{Binding IsRotationVisible, Converter={StaticResource BoolToVis}}"
                                                      AddKeyframeCommand="{Binding DataContext.AddKeyframeCommand, RelativeSource={RelativeSource AncestorType=comp:TrackHeader}}"
                                                      CommandParameter="Rotation">
                                <comp:DraggableValueBox DragSpeed="1" NumberFormat="0.0"
                                                        Value="{Binding RotationVM.Value, Mode=TwoWay}" />
                            </comp:TrackHeaderProperty>

                            <comp:TrackHeaderProperty Header="Opacity"
                                                      Visibility="{Binding IsOpacityVisible, Converter={StaticResource BoolToVis}}"
                                                      AddKeyframeCommand="{Binding DataContext.AddKeyframeCommand, RelativeSource={RelativeSource AncestorType=comp:TrackHeader}}"
                                                      CommandParameter="Opacity">
                                <comp:DraggableValueBox DragSpeed="1" NumberFormat="0"
                                                        Minimum="0"
                                                        Maximum="100"
                                                        Value="{Binding OpacityVM.Value, Mode=TwoWay}" />
                            </comp:TrackHeaderProperty>

                            <comp:TrackHeaderProperty Header="Speed"
                                                      Visibility="{Binding IsSpeedVisible, Converter={StaticResource BoolToVis}}"
                                                      AddKeyframeCommand="{Binding DataContext.AddKeyframeCommand, RelativeSource={RelativeSource AncestorType=comp:TrackHeader}}"
                                                      CommandParameter="Speed">
                                <comp:DraggableValueBox DragSpeed="0.1" NumberFormat="0.00"
                                                        Value="{Binding SpeedVM.Value, Mode=TwoWay}" />
                            </comp:TrackHeaderProperty>

                        </StackPanel>



                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type comp:TrackHeader}">

        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />


        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <comp:TrackHeaderJudgementLine />
                </DataTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="{x:Type nodify:ItemContainer}">
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="SelectedBrush" Value="Transparent" />
                    <Setter Property="HighlightBrush" Value="Transparent" />
                    <Setter Property="Background" Value="Transparent" />

                    <Setter Property="Margin" Value="0" />

                    <Setter Property="IsDraggable" Value="False" />
                    <Setter Property="Location" Value="{Binding Location, Mode=OneWay}" />

                    <Setter Property="Width" Value="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType={x:Type comp:TrackHeader}}}" />
                </Style>
            </Setter.Value>
        </Setter>


    </Style>



    <Style TargetType="{x:Type comp:TrackHeaderProperty}">
        <Setter Property="Margin" Value="25,0,5,0" />
        <Setter Property="Height" Value="{x:Static services:TrackLayoutService.PropertyRowHeightValue}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type comp:TrackHeaderProperty}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Width="10" Height="10"
                                Command="{TemplateBinding AddKeyframeCommand}"
                                CommandParameter="{TemplateBinding CommandParameter}"
                                Background="Transparent" FocusVisualStyle="{x:Null}"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Path x:Name="Diamond" Data="M 5 0 L 10 5 L 5 10 L 0 5 Z"
                                          Fill="Transparent" Stroke="#A0A0A0" StrokeThickness="1.5" Stretch="Uniform" />
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Diamond" Property="Stroke" Value="#FFFFFF" />
                                            <Setter TargetName="Diamond" Property="Fill" Value="#33FFFFFF" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Diamond" Property="Stroke" Value="#007ACC" />
                                            <Setter TargetName="Diamond" Property="Fill" Value="#007ACC" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <TextBlock Grid.Column="1"
                                   Text="{TemplateBinding Header}"
                                   Foreground="#D1D1D1"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"
                                   FontSize="12" />

                        <ContentPresenter Grid.Column="2"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>



    <Style TargetType="{x:Type comp:TimeLine}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="GridCellSize" Value="50" />
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="{x:Type nodify:ItemContainer}">
                    <Setter Property="Location" Value="{Binding Location, Mode=OneWay}" />

                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}" />

                    <Setter Property="IsDraggable" Value="False" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="0" />

                    <Setter Property="Margin" Value="0" />
                    <Setter Property="SelectedBrush" Value="Transparent" />
                    <Setter Property="HighlightBrush" Value="Transparent" />
                </Style>
            </Setter.Value>
        </Setter>

    </Style>


    <Style TargetType="{x:Type comp:KeyFrame}">
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type comp:KeyFrame}">
                    <Grid Background="{TemplateBinding Background}">
                        <Path x:Name="DiamondPath"
                              Data="M 5 0 L 10 5 L 5 10 L 0 5 Z"
                              Fill="#A0A0A0"
                              Stroke="#D1D1D1"
                              StrokeThickness="1"
                              Stretch="Uniform" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="DiamondPath" Property="Fill" Value="#FFFFFF" />
                            <Setter TargetName="DiamondPath" Property="Stroke" Value="#007ACC" />
                        </Trigger>

                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="DiamondPath" Property="Fill" Value="#007ACC" />
                            <Setter TargetName="DiamondPath" Property="Stroke" Value="#FFFFFF" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type comp:Playhead}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Margin" Value="-16,0,0,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type comp:Playhead}">
                    <Grid>
                        <Rectangle Width="1.5"
                                   Fill="#FF3333"
                                   HorizontalAlignment="Center"
                                   IsHitTestVisible="False" />

                        <Path Data="M 0 0 L 16 0 L 8 10 Z"
                              Fill="#FF3333"
                              Height="14"
                              VerticalAlignment="Top"
                              Margin="8,0,0,0" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
