<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:comp="clr-namespace:Axphi.Components"
    xmlns:data="clr-namespace:Axphi.Data;assembly=Axphi.Data">


    <Style TargetType="{x:Type comp:TabPane}">
        <Setter Property="Background" Value="#1f1f1f"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type comp:TabPane}">
                    <Border Background="#3d3d3d"
                            BorderBrush="#3d3d3d"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="1*"/>
                            </Grid.RowDefinitions>

                            <ContentPresenter Grid.Row="0"
                                              Margin="2"
                                              ContentSource="Header"
                                              TextBlock.Foreground="#eeeeee"/>
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type comp:ChartTimeline}">
        <Setter Property="Background" Value="#1f1f1f"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type comp:ChartTimeline}">
                    <Border Background="#3d3d3d"
                            BorderBrush="#3d3d3d"
                            BorderThickness="1">
                        <DockPanel Grid.IsSharedSizeScope="True">
                            <Grid DockPanel.Dock="Top">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>
                            </Grid>
                            <ItemsControl>
                                <ItemsControl.Resources>
                                    <DataTemplate DataType="{x:Type data:JudgementLine}">
                                        <Grid>

                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.Resources>
                            </ItemsControl>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
