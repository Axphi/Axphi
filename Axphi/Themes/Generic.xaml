<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ws="https://schemas.elecho.dev/wpfsuite"
    xmlns:comp="clr-namespace:Axphi.Components"
    xmlns:data="clr-namespace:Axphi.Data;assembly=Axphi.Data">


    <Style TargetType="{x:Type comp:TabPane}">
        <Setter Property="Background" Value="#1f1f1f"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type comp:TabPane}">
                    <Border Background="#3d3d3d"
                            BorderBrush="#3d3d3d"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="1*"/>
                            </Grid.RowDefinitions>

                            <ContentPresenter Grid.Row="0"
                                              Margin="2"
                                              ContentSource="Header"
                                              TextBlock.Foreground="#eeeeee"/>
                            <Border Grid.Row="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type comp:ChartTimeline}">
        <Setter Property="Background" Value="#1f1f1f"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type comp:ChartTimeline}">
                    <Border Background="#3d3d3d"
                            BorderBrush="#3d3d3d"
                            BorderThickness="1">
                        <DockPanel Grid.IsSharedSizeScope="True">
                            <Grid DockPanel.Dock="Top"
                                  Height="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="PART_TimelineHeaderColumn"
                                                      Width="100" 
                                                      MinWidth="10"
                                                      SharedSizeGroup="Left"/>
                                    <ColumnDefinition x:Name="PART_TimelineSplitterColumn"
                                                      Width="3"
                                                      SharedSizeGroup="Splitter"/>
                                    <ColumnDefinition MinWidth="10"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#3d3d3d">
                                    <TextBlock Text="Objects"/>
                                </Border>
                                <GridSplitter Grid.Column="1"
                                              Background="Transparent"
                                              VerticalAlignment="Stretch"
                                              HorizontalAlignment="Stretch"/>
                                <Border Grid.Column="2">
                                    <comp:ChartTimelineRuler Context="{Binding RelativeSource={RelativeSource Mode=TemplatedParent}}"/>
                                </Border>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=Chart.JudgementLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type data:JudgementLine}">
                                        <Grid>
                                            <comp:TimelineExpander>
                                                <comp:TimelineExpander.Header>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Line: "/>
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </StackPanel>
                                                </comp:TimelineExpander.Header>
                                                <comp:TimelineExpander.HeaderBackgroundSlot>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" SharedSizeGroup="Left"/>
                                                            <ColumnDefinition Width="3" SharedSizeGroup="Splitter"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <Rectangle Fill="#2d4f84"/>
                                                    </Grid>
                                                </comp:TimelineExpander.HeaderBackgroundSlot>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition SharedSizeGroup="Left"/>
                                                        <ColumnDefinition Width="3"/>
                                                        <ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Grid.Row="0" Grid.Column="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition/>
                                                        </Grid.ColumnDefinitions>
                                                        <UniformGrid Columns="1">
                                                            <TextBlock Text="Anchor"/>
                                                            <TextBlock Text="Position"/>
                                                            <TextBlock Text="Scale"/>
                                                            <TextBlock Text="Rotation"/>
                                                            <TextBlock Text="Opacity"/>
                                                            <TextBlock Text="Speed"/>
                                                        </UniformGrid>
                                                        <UniformGrid Grid.Column="1" Columns="1"
                                                                     Margin="4 0 0 0">
                                                            <ws:ToggleButton/>
                                                            <ws:ToggleButton/>
                                                            <ws:ToggleButton/>
                                                            <ws:ToggleButton/>
                                                            <ws:ToggleButton/>
                                                            <ws:ToggleButton/>
                                                        </UniformGrid>
                                                    </Grid>
                                                    <Rectangle Grid.Row="0"
                                                               Grid.Column="2"
                                                               Margin="0 4 4 4"
                                                               Fill="#131313"
                                                               RadiusX="2"
                                                               RadiusY="2"/>
                                                    <StackPanel Grid.Row="1"
                                                                Grid.ColumnSpan="3">
                                                        <comp:TimelineExpander Header="Notes"
                                                                             IndicatorFill="#1e88da"
                                                                             HeaderBackground="Transparent"
                                                                             IsExpanded="True">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Left"/>
                                                                    <ColumnDefinition Width="3" SharedSizeGroup="Splitter"/>
                                                                    <ColumnDefinition/>
                                                                </Grid.ColumnDefinitions>

                                                                <Border Grid.Column="2" 
                                                                        Margin="0 4 4 4"
                                                                        Height="20"
                                                                        Background="#151515"
                                                                        BorderBrush="#262626"
                                                                        BorderThickness="1"
                                                                        ClipToBounds="True">
                                                                    <ItemsControl ItemsSource="{Binding Notes}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <comp:TimelineTrackPanel Context="{Binding RelativeSource={RelativeSource AncestorType={x:Type comp:ChartTimeline}}}"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemContainerStyle>
                                                                            <Style TargetType="{x:Type ContentPresenter}">
                                                                                <Setter Property="comp:TimelineTrackPanel.Time"
                                                                                    Value="{Binding HitTime}"/>
                                                                            </Style>
                                                                        </ItemsControl.ItemContainerStyle>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate DataType="{x:Type data:Note}">
                                                                                <Border Width="10"
                                                                                    Height="12"
                                                                                    Margin="0 4 0 0"
                                                                                    CornerRadius="2">
                                                                                    <Border.Style>
                                                                                        <Style TargetType="{x:Type Border}">
                                                                                            <Setter Property="Background" Value="#5285f3"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding Kind}" Value="Drag">
                                                                                                    <Setter Property="Background" Value="#ffde91"/>
                                                                                                </DataTrigger>
                                                                                                <DataTrigger Binding="{Binding Kind}" Value="Hold">
                                                                                                    <Setter Property="Background" Value="#51b4ff"/>
                                                                                                </DataTrigger>
                                                                                                <DataTrigger Binding="{Binding Kind}" Value="Flick">
                                                                                                    <Setter Property="Background" Value="#ff5f5f"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Border.Style>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </Border>
                                                            </Grid>
                                                        </comp:TimelineExpander>
                                                    </StackPanel>
                                                </Grid>
                                            </comp:TimelineExpander>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type comp:TimelineExpander}">
        <Setter Property="Background" Value="#252525"/>
        <Setter Property="IndicatorFill" Value="#ffd700"/>
        <Setter Property="ToggleButtonStroke" Value="#d6d6d6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type comp:TimelineExpander}">
                    <ControlTemplate.Resources>
                        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
                    </ControlTemplate.Resources>

                    <Border Background="{TemplateBinding Background}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!--Header 背景-->
                            <Rectangle Grid.ColumnSpan="2"
                                       Fill="{TemplateBinding HeaderBackground}"/>
                            <ContentPresenter Grid.ColumnSpan="2" 
                                              Content="{TemplateBinding HeaderBackgroundSlot}"
                                              ContentTemplate="{TemplateBinding HeaderBackgroundSlotTemplate}"/>

                            <!--图标-->
                            <StackPanel Orientation="Horizontal"
                                        Margin="0 0 4 0">
                                <Rectangle Width="{TemplateBinding IndicatorThickness}"
                                           Fill="{TemplateBinding IndicatorFill}"
                                           VerticalAlignment="Stretch"/>
                                <ContentPresenter Content="{TemplateBinding Icon}"
                                              ContentTemplate="{TemplateBinding IconTemplate}"/>
                            </StackPanel>

                            <!--Toggle button 和 Header-->
                            <Grid Grid.Column="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <ToggleButton IsChecked="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=IsExpanded}"
                                              Foreground="{TemplateBinding ToggleButtonStroke}"
                                              Margin="0 0 4 0">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="contentRoot" 
                                                    Background="Transparent"
                                                    Width="10" Height="10"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Grid VerticalAlignment="Center"
                                                      HorizontalAlignment="Center">
                                                    <Line X1="0" Y1="0" X2="5" Y2="5" Stroke="{TemplateBinding Foreground}" StrokeThickness="1"/>
                                                    <Line X1="5" Y1="0" X2="0" Y2="5" Stroke="{TemplateBinding Foreground}" StrokeThickness="1" Margin="0 5 0 0"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="contentRoot"
                                                            Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="90"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <ContentPresenter Grid.Column="1"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}"/>
                            </Grid>

                            <!--主内容-->
                            <ContentPresenter Grid.Row="1"
                                              Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                              Visibility="{Binding RelativeSource={RelativeSource Mode=TemplatedParent},Path=IsExpanded,Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type comp:ChartTimelineRuler}">

    </Style>
</ResourceDictionary>
