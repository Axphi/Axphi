<Window
    x:Class="Axphi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:comp="clr-namespace:Axphi.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Axphi"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ws="https://schemas.elecho.dev/wpfsuite"
    xmlns:v="clr-namespace:Axphi.Views"
    Title="Axphi"
    Width="1200"
    Height="650"
    d:DataContext="{d:DesignInstance Type=local:MainWindow, IsDesignTimeCreatable=False}"
    ws:WindowOption.IsCaptionMenuVisible="False"
    Background="#1f1f1f"
    Foreground="#d6d6d6"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome />
    </WindowChrome.WindowChrome>

    <!--  资源  -->
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <GridLength x:Key="TimelineLeftPanelWidth">180</GridLength>

            <Style x:Key="ThinHorizontalSplitterStyle" TargetType="GridSplitter">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="SnapsToDevicePixels" Value="True" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridSplitter">
                            <Grid Background="Transparent">
                                <Rectangle x:Name="Line"
                                           Height="1"
                                           VerticalAlignment="Center"
                                           Margin="10,0"
                                           Fill="{StaticResource SplitterLineBrush}" />
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Line" Property="Fill" Value="{StaticResource SplitterLineHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Line" Property="Fill" Value="{StaticResource SplitterLineHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="Line" Property="Fill" Value="{StaticResource SplitterLineDragBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding FileActions.SaveChartCommand}" />
    </Window.InputBindings>

    <!--  主页面  -->
    <Grid>
        <ws:WindowContentAdapter>
            <DockPanel>
                <!--  标题栏  -->
                <v:TitleBar DockPanel.Dock="Top" />
                <!--  核心区域  -->
                <Grid Margin="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1.618*" MinHeight="180" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="1*" MinHeight="180" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" MinWidth="220" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="2.8*" MinWidth="360" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="1*" MinWidth="220" />
                    </Grid.ColumnDefinitions>

                    <!--  贝塞尔工具  -->
                    <comp:TabPane
                    Grid.Row="0"
                    Grid.Column="0"
                    Header="Flow">
                        <Grid>
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <comp:BezierCurveEditor
                                X1="{Binding BezierViewModel.X1, Mode=TwoWay}"
                                X2="{Binding BezierViewModel.X2, Mode=TwoWay}"
                                Y1="{Binding BezierViewModel.Y1, Mode=TwoWay}"
                                Y2="{Binding BezierViewModel.Y2, Mode=TwoWay}" />
                                <StackPanel
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                    <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.X1}" />
                                    <TextBlock Text=", " />
                                    <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.Y1}" />
                                    <TextBlock Text=", " />
                                    <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.X2}" />
                                    <TextBlock Text=", " />
                                    <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.Y2}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </comp:TabPane>


                    <!--  渲染设置  -->
                    <comp:TabPane
                    Grid.Row="0"
                    Grid.Column="4"
                    Header="Display Controls">
                        <StackPanel Margin="10" Orientation="Vertical" VerticalAlignment="Top">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                VerticalAlignment="Center"
                                Foreground="#d6d6d6"
                                Text="播放速度" />
                                <comp:DraggableValueBox
                                Margin="8,0,0,0"
                                Width="72"
                                DragSpeed="0.01"
                                Minimum="0.1"
                                Maximum="4"
                                NumberFormat="0.00'x'"
                                Value="{Binding ElementName=MainChartDisplay, Path=PlaybackSpeed, Mode=TwoWay}" />
                                <CheckBox
                                Margin="10,0,0,0"
                                VerticalAlignment="Center"
                                IsChecked="{Binding ElementName=MainChartDisplay, Path=PreserveAudioPitch, Mode=TwoWay}" />
                                <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="#d6d6d6"
                                Text="保持音高" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <CheckBox
                                VerticalAlignment="Center"
                                IsChecked="{Binding ElementName=MainChartDisplay, Path=ShowAuxiliaryUi, Mode=TwoWay}" />
                                <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="#d6d6d6"
                                Text="显示辅助UI" />
                            </StackPanel>

                            <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                <CheckBox
                                VerticalAlignment="Center"
                                IsChecked="{Binding ElementName=MainChartDisplay, Path=ShowNoteCenters, Mode=TwoWay}"
                                IsEnabled="{Binding ElementName=MainChartDisplay, Path=ShowAuxiliaryUi}" />
                                <TextBlock
                                Margin="6,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="#d6d6d6"
                                Text="显示note中心" />
                            </StackPanel>

                            <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                <TextBlock
                                VerticalAlignment="Center"
                                Foreground="#d6d6d6"
                                Text="背景暗层" />
                                <comp:DraggableValueBox
                                Margin="8,0,0,0"
                                Width="72"
                                DragSpeed="0.01"
                                Minimum="0"
                                Maximum="1"
                                NumberFormat="0.00"
                                Value="{Binding ElementName=MainChartDisplay, Path=BackgroundDimOpacity, Mode=TwoWay}" />
                            </StackPanel>
                        </StackPanel>
                    </comp:TabPane>


                    <!--  时间线区  -->
                    


                    <comp:TimeLine Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"/>



                    <!--  右下角  -->
                    <comp:TabPane
                    Grid.Row="2"
                    Grid.Column="4"
                    Header="Project">
                        <StackPanel Margin="10">
                            <StackPanel Orientation="Horizontal">
                                <StackPanel>
                                    <ws:Button Command="{Binding FileActions.ImportMusicCommand}" Content="Import Music" Padding="15,5" />
                                    <ws:Button Command="{Binding FileActions.ImportIllustrationCommand}" Content="Import Illustration" Padding="15,5" Margin="0,8,0,0" />
                                </StackPanel>

                                
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <TextBlock Text="Total Ticks:" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#d6d6d6" />

                                <comp:DraggableValueBox DragSpeed="100"
                                                        NumberFormat="0"
                                                        Value="0"
                                                        IsEnabled="False"
                                                        ToolTip="该功能待重构后接回"
                                                        Width="80" />
                            </StackPanel>
                        </StackPanel>
                    </comp:TabPane>

                    <!--  渲染窗口  -->
                    <Grid Grid.Row="0" Grid.Column="2">
                        <v:ChartDisplay x:Name="MainChartDisplay" />

                        <Grid IsHitTestVisible="True" ClipToBounds="True">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </Style>
                            </Grid.Style>

                            <Border Background="#e0000000" />

                            
                        </Grid>
                    </Grid>

                    <GridSplitter Grid.Row="0"
                                  Grid.RowSpan="1"
                                  Grid.Column="1"
                                  HorizontalAlignment="Stretch"
                                  Width="6"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="False"
                                  Style="{StaticResource ThinVerticalSplitterStyle}"
                                  Cursor="SizeWE"
                                  Panel.ZIndex="3000" />

                    <GridSplitter Grid.Row="0"
                                  Grid.RowSpan="3"
                                  Grid.Column="3"
                                  HorizontalAlignment="Stretch"
                                  Width="6"
                                  ResizeDirection="Columns"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="False"
                                  Style="{StaticResource ThinVerticalSplitterStyle}"
                                  Cursor="SizeWE"
                                  Panel.ZIndex="3000" />

                    <GridSplitter Grid.Row="1"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="5"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  ResizeDirection="Rows"
                                  ResizeBehavior="PreviousAndNext"
                                  ShowsPreview="False"
                                  Style="{StaticResource ThinHorizontalSplitterStyle}"
                                  Cursor="SizeNS"
                                  Panel.ZIndex="3000" />
                </Grid>
            </DockPanel>
        </ws:WindowContentAdapter>

        <Canvas x:Name="GlobalOverlayCanvas"
                IsHitTestVisible="False"
                Panel.ZIndex="99999">
            <Line x:Name="ParentBindingGlobalPreviewLine"
                  Visibility="Collapsed"
                  Stroke="#8AB4F8"
                  StrokeThickness="1.5"
                  StrokeDashArray="2,2"
                  SnapsToDevicePixels="True" />
        </Canvas>
    </Grid>
</Window>
