<UserControl x:Class="Axphi.Components.DraggableValueBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:EleCho.WpfSuite.ValueConverters;assembly=EleCho.WpfSuite.ValueConverters"
             mc:Ignorable="d"
             d:DesignHeight="30" d:DesignWidth="300"
             Name="Root">

    <UserControl.Resources>
        <conv:ValueConverterGroup x:Key="InvertBooleanToVisibilityConverter">
            <conv:InvertBooleanConverter />
            <conv:BooleanToVisibilityConverter />
        </conv:ValueConverterGroup>
    </UserControl.Resources>

    <Grid Name="Container" Background="Transparent"
          Cursor="SizeWE"
          MouseLeftButtonDown="Number_MouseDown"
          MouseLeftButtonUp="Number_MouseUp"
          MouseMove="Number_MouseMove">
        <Border x:Name="HoverBorder"
                Background="Transparent"
                CornerRadius="2"
                Padding="2,1">
            <Grid>
                <TextBlock Text="{Binding DisplayText, ElementName=Root}"
                           HorizontalAlignment="Stretch"
                           TextAlignment="Center"
                           Foreground="#007ACC"
                           FontWeight="Bold"
                           Visibility="{Binding IsEditable, ElementName=Root, Converter={StaticResource InvertBooleanToVisibilityConverter}}" />

                <TextBox x:Name="EditBox"
                         Padding="0"
                         Margin="0"
                         Foreground="White"
                         CaretBrush="White"
                         Background="#55555555"
                         BorderThickness="0"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         FontWeight="Bold"
                         KeyDown="EditBox_KeyDown"
                         LostFocus="EditBox_LostFocus"
                         Visibility="{Binding IsEditable, ElementName=Root, Converter={x:Static conv:BooleanToVisibilityConverter.Instance}}" />
            </Grid>
        </Border>

        <Grid.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetName="HoverBorder"
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="#33FFFFFF" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetName="HoverBorder"
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="Transparent" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
    </Grid>

</UserControl>