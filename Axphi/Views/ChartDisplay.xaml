<UserControl
    x:Class="Axphi.Views.ChartDisplay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:comp="clr-namespace:Axphi.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ws="https://schemas.elecho.dev/wpfsuite"
    x:Name="Root"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <DockPanel>
        <StackPanel
            HorizontalAlignment="Center"
            DockPanel.Dock="Bottom"
            Orientation="Horizontal">

            <ws:Button Command="{Binding ElementName=Root, Path=PlayPauseChartRenderingCommand}" Content="Play/Pause" />

            <ws:Button Command="{Binding ElementName=Root, Path=StopChartRenderingCommand}" Content="Stop" />
        </StackPanel>

        <comp:ChartRenderer
            x:Name="InternalChartRenderer"
            Chart="{Binding ProjectManager.EditingProject.Chart}"
            ClipToBounds="True" />
    </DockPanel>
</UserControl>