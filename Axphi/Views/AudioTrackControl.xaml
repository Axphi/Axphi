<UserControl x:Class="Axphi.Views.AudioTrackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Axphi.Views"
             xmlns:comp="clr-namespace:Axphi.Components"
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="2.8*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="0,0,2,2" Background="#2A2A2A" BorderBrush="#444" BorderThickness="0,0,0,1" VerticalAlignment="Top">
            <StackPanel>
                <Grid Height="20" Background="Transparent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Rectangle Grid.Column="0" Fill="#28E857" />
                    <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#28E857" Text="♫" FontSize="14" />

                    <CheckBox Grid.Column="2" IsChecked="{Binding IsExpanded}" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <CheckBox.Template>
                            <ControlTemplate TargetType="CheckBox">
                                <Grid Background="Transparent" Width="16" Height="16" Cursor="Hand">
                                    <Path x:Name="Arrow" Data="M 4,4 L 10,10 L 16,4" Stroke="#888" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter TargetName="Arrow" Property="Data" Value="M 6,2 L 12,8 L 6,14" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </CheckBox.Template>
                    </CheckBox>

                    <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="5,0,0,0" VerticalAlignment="Center">
                        <TextBlock Foreground="#d6d6d6" Text="Audio (BGM)" FontWeight="Bold" />
                        <TextBlock Foreground="#888" Text="{Binding AudioDurationSeconds, StringFormat=' ({0:F1}s)'}" Margin="5,0,0,0" />
                    </StackPanel>
                </Grid>

                <Grid Height="60">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="TrackScrollViewer"
                      Grid.Column="1" HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      PreviewMouseWheel="InnerTrack_PreviewMouseWheel">

            <Border Margin="0,0,0,2" Background="#1e1e1e" BorderBrush="#444" BorderThickness="0,0,0,1" VerticalAlignment="Top">
                <Canvas Margin="8,0,0,0" Width="{Binding Timeline.TotalPixelWidth}" HorizontalAlignment="Left">
                    <Canvas.Style>
                        <Style TargetType="Canvas">
                            <Setter Property="Height" Value="80" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                    <Setter Property="Height" Value="20" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Canvas.Style>

                    <Thumb Canvas.Left="{Binding LayerPixelXOffset}"
                           DragStarted="AudioThumb_DragStarted"
                           DragDelta="AudioThumb_DragDelta"
                           DragCompleted="AudioThumb_DragCompleted">
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Grid Width="{Binding LayerPixelWidth}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="20" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Rectangle Grid.Row="0" x:Name="LayerRect" Fill="#28E857" Opacity="0.5" />

                                    <Border Grid.Row="1" Height="60" Background="#1128E857" BorderBrush="#2228E857" BorderThickness="1,0,1,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <comp:WaveformRenderer Peaks="{Binding WaveformPeaks}" Margin="0,2" />


                                    </Border>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="LayerRect" Property="Opacity" Value="0.8" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Canvas>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>