<UserControl x:Class="Axphi.Views.JudgementLineEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:comp="clr-namespace:Axphi.Components"
         Loaded="UserControl_Loaded"
             mc:Ignorable="d"
             d:DesignHeight="380" d:DesignWidth="1200">
    <Grid x:Name="EditorRoot"
          Background="Transparent"
          ClipToBounds="True"
        Focusable="True"
                MouseLeave="EditorRoot_MouseLeave"
        PreviewKeyDown="EditorRoot_PreviewKeyDown"
          PreviewMouseDown="EditorRoot_PreviewMouseDown"
          PreviewMouseMove="EditorRoot_PreviewMouseMove"
          PreviewMouseUp="EditorRoot_PreviewMouseUp"
          PreviewMouseWheel="EditorRoot_PreviewMouseWheel">
        <comp:JudgementLineEditorCanvas x:Name="EditorCanvas"
                        Focusable="True"
                        Editor="{Binding}"
                        MouseMove="EditorCanvas_MouseMove"
                        />

        <Border x:Name="EditorHud"
            HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="12"
                Padding="12,10"
                Background="#78131A24"
                BorderBrush="#664C5D78"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Foreground="#F4F6FB" FontSize="14" FontWeight="Bold" Text="{Binding ActiveTrackName}" />
                    <TextBlock Foreground="#8E9AAF" FontSize="11" Text="判定线编辑模式" />
                    <TextBlock Foreground="#B7C9E8" FontSize="10" Text="Q Tap  W Hold  E Drag  R Flick" />
                    <TextBlock Foreground="#9FC1FF" FontSize="10" Text="{Binding PlacementHint}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="12,0,10,0" Orientation="Vertical">
                    <TextBlock Foreground="#8E9AAF" FontSize="10" Text="Current Note" />
                    <ComboBox Width="92" ItemsSource="{Binding NoteKindOptions}" SelectedItem="{Binding CurrentNoteKind}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0" Orientation="Vertical">
                    <TextBlock Foreground="#8E9AAF" FontSize="10" Text="Divisions" />
                    <comp:DraggableValueBox Width="72"
                                            HorizontalAlignment="Center"
                                            DragSpeed="1"
                                            NumberFormat="0"
                                            Minimum="4"
                                            Maximum="64"
                                            Value="{Binding HorizontalDivisionsValue, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,10,0" Orientation="Vertical">
                    <TextBlock Foreground="#8E9AAF" FontSize="10" Text="Zoom" />
                    <TextBlock Foreground="#D7E6FF" FontSize="11" Text="{Binding ViewZoom, StringFormat=F2}" />
                </StackPanel>

                <Button Grid.Column="4" Width="64" Margin="0,18,10,0" Command="{Binding ResetViewCommand}" Content="Reset" />
                <Button Grid.Column="5" Width="64" Margin="0,18,0,0" Command="{Binding CloseCommand}" Content="Close" />
            </Grid>
        </Border>
    </Grid>
</UserControl>