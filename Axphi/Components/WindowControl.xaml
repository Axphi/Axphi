<UserControl
    x:Class="Axphi.Components.WindowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Axphi.Components"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ws="https://schemas.elecho.dev/wpfsuite"
    mc:Ignorable="d">
    <Grid>
        <StackPanel
            Margin="0"
            Height="34"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <StackPanel.Resources>
                <Style x:Key="CaptionButton" TargetType="{x:Type ws:Button}">
                    <Setter Property="Width" Value="50" />
                    <Setter Property="Height" Value="34" />
                    <Setter Property="Margin" Value="0,0,0,0" />
                    <Setter Property="CornerRadius" Value="0" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="HoverBorderBrush" Value="#3d3d3d" />
                    <Setter Property="PressedBorderBrush" Value="Transparent" />
                    <Setter Property="Background" Value="#1f1f1f" />
                    <Setter Property="HoverBackground" Value="#3d3d3d" />
                    <Setter Property="PressedBackground" Value="#4f4f4f" />
                    <Setter Property="Foreground" Value="#b2b2b2" />
                    <Setter Property="HoverForeground" Value="#fafafa" />
                </Style>
            </StackPanel.Resources>

            <ws:Button
                ws:WindowOption.IsMinimumButton="True"
                Click="MinimizeSelf_Click"
                Style="{StaticResource CaptionButton}">
                <Path Data="M 0,5 L 10,5"
                      Width="10" Height="10" Stretch="None"
                      RenderOptions.EdgeMode="Aliased"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ws:Button}}"
                      StrokeThickness="1" />
            </ws:Button>

            <ws:Button
                ws:WindowOption.IsMaximumButton="True"
                Click="MaximizeRestoreSelf_Click"
                Style="{StaticResource CaptionButton}">
                <Path Data="M 1,1 L 9,1 L 9,9 L 1,9 Z"
                      RenderOptions.EdgeMode="Aliased"
                      Width="10" Height="10" Stretch="None"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ws:Button}}"
                      StrokeThickness="1" />
            </ws:Button>

            <ws:Button
                ws:WindowOption.IsCloseButton="True"
                Click="CloseSelf_Click"
                HoverBackground="#e81123"
                HoverBorderBrush="#e81123"
                HoverForeground="#ffffff"
                Style="{StaticResource CaptionButton}">
                <Path Data="M 0,0 L 10,10 M 0,10 L 10,0"
                      RenderOptions.EdgeMode="Aliased"
                      Width="10" Height="10" Stretch="None"
                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ws:Button}}"
                      StrokeThickness="1" />
            </ws:Button>
        </StackPanel>
    </Grid>
</UserControl>