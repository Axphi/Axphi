<UserControl x:Class="Axphi.Views.TrackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Axphi.Views"
             xmlns:comp="clr-namespace:Axphi.Components"
             xmlns:vm="clr-namespace:Axphi.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">


    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="2.8*" />
        </Grid.ColumnDefinitions>

        <!--  左侧  -->
        <Border Grid.Column="0" Margin="0,0,2,2" Background="#2A2A2A" BorderBrush="#444" BorderThickness="0,0,0,1">
            <StackPanel x:Name="JudgementLineLayer">
                <!--  图层条  -->
                <Grid Height="20" Background="Transparent" PreviewMouseLeftButtonDown="LayerHeader_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="LayerHeader_PreviewMouseLeftButtonUp">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Fill="#FFD700" />
                    <ToggleButton Grid.Column="1" Cursor="Hand" IsChecked="{Binding IsExpanded, Mode=TwoWay}">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <TextBlock x:Name="ArrowText" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" FontWeight="Bold" Foreground="#d6d6d6" Text="&gt;" />
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="ArrowText" Property="Text" Value="v" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ArrowText" Property="Foreground" Value="#FFD700" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <TextBlock Grid.Column="2" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="#d6d6d6" Text="{Binding TrackName}" />
                        <Button Grid.Column="3"
                            Margin="0,2,6,2"
                            Padding="6,0"
                            VerticalAlignment="Center"
                            Command="{Binding EnterJudgementLineEditorCommand}"
                            Content="Edit"
                            FontSize="10"
                            Background="#394459"
                            Foreground="#DDE6F6"
                            BorderBrush="#55627A"
                            BorderThickness="1"
                            Cursor="Hand" />
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Background" Value="Transparent" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSelectedChildren}" Value="True">
                                    <Setter Property="Background" Value="#243754" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsLayerSelected}" Value="True">
                                    <Setter Property="Background" Value="#2D4F84" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                </Grid>
                <!--  四个属性和 note  -->
                <StackPanel Margin="24,0,0,0" Background="#252525" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                    <!--  Position  -->
                    <Grid Height="20">
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#aaa" Text="Position" />
                        <Button Command="{Binding AddPositionKeyframeCommand}"
                                Width="12" Height="12"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="添加/更新关键帧">
                            <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z"
                                  Fill="#888" Stretch="Fill" />
                        </Button>
                        <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                            <comp:DraggableValueBox DragSpeed="0.01" NumberFormat="0.00" Value="{Binding CurrentOffsetX, Mode=TwoWay}" />
                            <TextBlock VerticalAlignment="Center" Foreground="#888" Text=", " />
                            <comp:DraggableValueBox DragSpeed="0.01" NumberFormat="0.00" Value="{Binding CurrentOffsetY, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                    <!--  Scale  -->
                    <Grid Height="20">
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#aaa" Text="Scale" />
                        <Button Command="{Binding AddScaleKeyframeCommand}"
                                Width="12" Height="12"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="添加/更新关键帧">
                            <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z"
                                  Fill="#888" Stretch="Fill" />
                        </Button>
                        <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                            <comp:DraggableValueBox DragSpeed="0.01" NumberFormat="0.00" Value="{Binding CurrentScaleX, Mode=TwoWay}" />
                            <TextBlock VerticalAlignment="Center" Foreground="#888" Text=", " />
                            <comp:DraggableValueBox DragSpeed="0.01" NumberFormat="0.00" Value="{Binding CurrentScaleY, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>
                    <!--  Rotation  -->
                    <Grid Height="20">
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#aaa" Text="Rotation" />
                        <Button Command="{Binding AddRotationKeyframeCommand}"
                                Width="12" Height="12"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="添加/更新关键帧">
                            <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z"
                                  Fill="#888" Stretch="Fill" />
                        </Button>
                        <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                            <comp:DraggableValueBox DragSpeed="1" NumberFormat="0.00" Value="{Binding CurrentRotation, Mode=TwoWay}" />
                            <TextBlock VerticalAlignment="Center" Foreground="#888" Text="°" />
                        </StackPanel>
                    </Grid>
                    <!--  Opacity  -->
                    <Grid Height="20">
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#aaa" Text="Opacity" />
                        <Button Command="{Binding AddOpacityKeyframeCommand}"
                                Width="12" Height="12"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="添加/更新关键帧">
                            <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z"
                                  Fill="#888" Stretch="Fill" />
                        </Button>
                        <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                            <comp:DraggableValueBox DragSpeed="1" Maximum="100" Minimum="0" NumberFormat="0.00" Value="{Binding CurrentOpacity, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>


                    <Grid Height="20">
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#aaa" Text="Speed" />
                        <Button Command="{Binding AddSpeedKeyframeCommand}"
                                Width="12" Height="12"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" ToolTip="添加/更新关键帧">
                            <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z" Fill="#888" Stretch="Fill" />
                        </Button>
                        <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                            <comp:DraggableOptionBox Value="{Binding CurrentSpeedMode, Mode=TwoWay}" ToolTip="速度渲染模式: Integral(最终) / Realtime(实时)">
                                <comp:DraggableOptionBox.Options>
                                    <comp:StringList>
                                        <sys:String>Integral</sys:String>
                                        <sys:String>Realtime</sys:String>
                                    </comp:StringList>
                                </comp:DraggableOptionBox.Options>
                            </comp:DraggableOptionBox>

                            <TextBlock VerticalAlignment="Center" Foreground="#555" Text=" | " Margin="4,0" />

                            <comp:DraggableValueBox DragSpeed="0.1" NumberFormat="0.00" Value="{Binding CurrentSpeed, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>



                    <!--  note  -->
                    <Grid Height="{Binding UITrackHeight}" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="20" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Rectangle Grid.Column="0" Fill="#1e88da" />

                        <ToggleButton Grid.Column="1" Cursor="Hand"
                                      VerticalAlignment="Top" Height="20"
                                      IsChecked="{Binding IsNoteExpanded, Mode=TwoWay}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <TextBlock x:Name="ArrowText" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Consolas" FontWeight="Bold" Foreground="#d6d6d6" Text="&gt;" />
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="ArrowText" Property="Text" Value="v" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ArrowText" Property="Foreground" Value="#1e88da" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Grid Grid.Column="2" VerticalAlignment="Top" Height="20">
                            <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" Foreground="#d6d6d6" Text="Note" />
                            <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">

                                <Button Command="{Binding AddNoteCommand}" CommandParameter="Tap" Width="14" Height="14" Margin="0,0,6,0" Cursor="Hand" ToolTip="添加 Tap">
                                    <Button.Template>
                                        <ControlTemplate>
                                            <Rectangle Fill="#5285F3" RadiusX="2" RadiusY="2" />
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Command="{Binding AddNoteCommand}" CommandParameter="Drag" Width="14" Height="14" Margin="0,0,6,0" Cursor="Hand" ToolTip="添加 Drag">
                                    <Button.Template>
                                        <ControlTemplate>
                                            <Rectangle Fill="#FFDE91" RadiusX="2" RadiusY="2" />
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Command="{Binding AddNoteCommand}" CommandParameter="Hold" Width="14" Height="14" Margin="0,0,6,0" Cursor="Hand" ToolTip="添加 Hold">
                                    <Button.Template>
                                        <ControlTemplate>
                                            <Rectangle Fill="#51B4FF" RadiusX="2" RadiusY="2" />
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Command="{Binding AddNoteCommand}" CommandParameter="Flick" Width="14" Height="14" Cursor="Hand" ToolTip="添加 Flick">
                                    <Button.Template>
                                        <ControlTemplate>
                                            <Rectangle Fill="#FF5F5F" RadiusX="2" RadiusY="2" />
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!--  note 属性  -->
                    <StackPanel Margin="24,0,0,0" Background="#252525" Visibility="{Binding IsNoteExpanded, Converter={StaticResource BoolToVis}}">
                        <StackPanel DataContext="{Binding Timeline.NoteSelectionPanel}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasSelection}" Value="True" />
                                                <Condition Binding="{Binding DataContext.IsNotePanelOwner, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <Grid Height="140">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Setter Property="MinHeight" Value="140" />
                                    </Style>
                                </Grid.Style>

                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSelection}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <TextBlock HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="11"
                                               Foreground="#7E7E7E"
                                               Text="请选择一个音符" />
                                </Grid>

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSelection}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>

                                    <Grid Height="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#d6d6d6" Text="{Binding SelectionTitle}" />
                                    <Border Grid.Column="1" Margin="0,2,10,2" Padding="6,0" Background="#2F4A73" CornerRadius="9">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SelectionModeHint}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock VerticalAlignment="Center" FontSize="10" Foreground="#D7E6FF" Text="{Binding SelectionModeHint}" />
                                    </Border>
                                </Grid>

                                    <Grid Height="20">
                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#aaa" Text="Kind" />
                                    <Button Command="{Binding AddNoteKindKeyframeCommand}"
                                            Width="12" Height="12"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" ToolTip="添加/更新关键帧">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditKeyframes}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z"
                                              Fill="#888" Stretch="Fill" />
                                    </Button>
                                    <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                        <comp:DraggableOptionBox Value="{Binding CurrentNoteKind, Mode=TwoWay}">
                                            <comp:DraggableOptionBox.Options>
                                                <comp:StringList>
                                                    <sys:String>Mixed</sys:String>
                                                    <sys:String>Tap</sys:String>
                                                    <sys:String>Drag</sys:String>
                                                    <sys:String>Hold</sys:String>
                                                    <sys:String>Flick</sys:String>
                                                </comp:StringList>
                                            </comp:DraggableOptionBox.Options>
                                        </comp:DraggableOptionBox>
                                    </StackPanel>
                                </Grid>

                                    <Grid Height="20">
                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#aaa" Text="Position" />
                                    <Button Command="{Binding AddPositionKeyframeCommand}"
                                            Width="12" Height="12"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand" ToolTip="添加/更新关键帧">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditKeyframes}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z" Fill="#888" Stretch="Fill" />
                                    </Button>
                                    <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                        <comp:DraggableValueBox DragSpeed="0.01" NumberFormat="0.00" Value="{Binding CurrentOffsetX, Mode=TwoWay}" />
                                        <TextBlock VerticalAlignment="Center" Foreground="#888" Text=", " />
                                        <comp:DraggableValueBox DragSpeed="0.01" NumberFormat="0.00" Value="{Binding CurrentOffsetY, Mode=TwoWay}" />
                                    </StackPanel>
                                </Grid>

                                    <Grid Height="20">
                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#aaa" Text="Scale" />
                                    <Button Command="{Binding AddScaleKeyframeCommand}"
                                            Width="12" Height="12"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand" ToolTip="添加/更新关键帧">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditKeyframes}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z" Fill="#888" Stretch="Fill" />
                                    </Button>
                                    <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                        <comp:DraggableValueBox DragSpeed="0.01" NumberFormat="0.00" Value="{Binding CurrentScaleX, Mode=TwoWay}" />
                                        <TextBlock VerticalAlignment="Center" Foreground="#888" Text=", " />
                                        <comp:DraggableValueBox DragSpeed="0.01" NumberFormat="0.00" Value="{Binding CurrentScaleY, Mode=TwoWay}" />
                                    </StackPanel>
                                </Grid>
                                    <Grid Height="20">
                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#aaa" Text="Rotation" />
                                    <Button Command="{Binding AddRotationKeyframeCommand}"
                                            Width="12" Height="12"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand" ToolTip="添加/更新关键帧">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditKeyframes}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z" Fill="#888" Stretch="Fill" />
                                    </Button>
                                    <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                        <comp:DraggableValueBox DragSpeed="1" NumberFormat="0.00" Value="{Binding CurrentRotation, Mode=TwoWay}" />

                                    </StackPanel>
                                </Grid>
                                    <Grid Height="20">
                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#aaa" Text="Opacity" />
                                    <Button Command="{Binding AddOpacityKeyframeCommand}"
                                            Width="12" Height="12"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand" ToolTip="添加/更新关键帧">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CanEditKeyframes}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Path Data="M 6,0 L 12,6 L 6,12 L 0,6 Z" Fill="#888" Stretch="Fill" />
                                    </Button>
                                    <StackPanel Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                        <comp:DraggableValueBox DragSpeed="1" Maximum="100" Minimum="0" NumberFormat="0.00" Value="{Binding CurrentOpacity, Mode=TwoWay}" />

                                    </StackPanel>
                                </Grid>

                                    <Grid Height="20">
                                    <TextBlock Margin="5,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#aaa" Text="Custom Speed" />
                                    <Grid Margin="0,0,10,0" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="62" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{Binding HasCustomSpeed, Mode=TwoWay}" IsThreeState="True" VerticalAlignment="Center" HorizontalAlignment="Left" Cursor="Hand">
                                        <CheckBox.Template>
                                            <ControlTemplate TargetType="CheckBox">
                                                <Grid Width="14" Height="14" Background="Transparent">
                                                    <Border x:Name="CheckBoxBorder"
                                                            Background="#252525"
                                                            BorderBrush="#5A5A5A"
                                                            BorderThickness="1"
                                                            CornerRadius="2" />
                                                    <Path x:Name="CheckMark"
                                                          Width="8"
                                                          Height="6"
                                                          Data="M 0,3 L 2.5,5.5 L 8,0"
                                                          Stretch="Fill"
                                                          Stroke="#FFFFFF"
                                                          StrokeThickness="1.6"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          Visibility="Collapsed"
                                                          HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                          Margin="0,1,0,0" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="CheckBoxBorder" Property="Background" Value="#29476D" />
                                                        <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#5285F3" />
                                                        <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="{x:Null}">
                                                        <Setter TargetName="CheckBoxBorder" Property="Background" Value="#3B3B3B" />
                                                        <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#9B9B9B" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="#8AAEFF" />
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="CheckBoxBorder" Property="Opacity" Value="0.45" />
                                                        <Setter TargetName="CheckMark" Property="Opacity" Value="0.45" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </CheckBox.Template>
                                    </CheckBox>
                                        <comp:DraggableValueBox Grid.Column="1"
                                                                Margin="6,0,0,0"
                                                                Width="56"
                                                                DragSpeed="0.1"
                                                                NumberFormat="0.00"
                                                                Value="{Binding CurrentCustomSpeed, Mode=TwoWay}">
                                            <comp:DraggableValueBox.Style>
                                                <Style TargetType="comp:DraggableValueBox">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasResolvedCustomSpeed}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </comp:DraggableValueBox.Style>
                                        </comp:DraggableValueBox>
                                    </Grid>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </Border>

        <!--  右侧  -->
        <ScrollViewer x:Name="TrackScrollViewer"
                      Grid.Column="1" HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      PreviewMouseWheel="InnerTrack_PreviewMouseWheel">
            <Border Margin="0,0,0,2" Background="#1e1e1e" BorderBrush="#444" BorderThickness="0,0,0,1">
                <StackPanel>

                    <!--  图层  -->
                    <Canvas Margin="8,0,0,0" Width="{Binding Timeline.TotalPixelWidth}" Height="20" HorizontalAlignment="Left">

                           <Thumb Canvas.Left="{Binding LayerPixelXOffset}"
                               PreviewMouseLeftButtonDown="LayerThumb_PreviewMouseLeftButtonDown"
                               PreviewMouseLeftButtonUp="LayerThumb_PreviewMouseLeftButtonUp"
                               DragStarted="LayerThumb_DragStarted"
                               DragDelta="LayerThumb_DragDelta"
                               DragCompleted="LayerThumb_DragCompleted">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">

                                    <Grid Width="{Binding LayerPixelWidth}" Height="20">

                                        <Rectangle x:Name="LayerRect" Fill="#374561"/>

                                        <Thumb Width="8" HorizontalAlignment="Left" Cursor="SizeWE"
                                               DragStarted="LayerLeftHandle_DragStarted"
                                               DragDelta="LayerLeftHandle_DragDelta"
                                               DragCompleted="LayerLeftHandle_DragCompleted">
                                            <Thumb.Template>
