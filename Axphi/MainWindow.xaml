<Window
    x:Class="Axphi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:comp="clr-namespace:Axphi.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Axphi"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ws="https://schemas.elecho.dev/wpfsuite"
    Title="MainWindow"
    Width="1200"
    Height="650"
    d:DataContext="{d:DesignInstance Type=local:MainWindow,
                                     IsDesignTimeCreatable=False}"
    ws:WindowOption.IsCaptionMenuVisible="False"
    Background="#1f1f1f"
    Foreground="#d6d6d6"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome />
    </WindowChrome.WindowChrome>

    <ws:WindowContentAdapter>
        <DockPanel>
            <Grid DockPanel.Dock="Top">
                <StackPanel
                    Margin="4,0,0,0"
                    Orientation="Horizontal"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock VerticalAlignment="Center" Text="LOGO" />
                    <ws:Menu Margin="4" VerticalAlignment="Center">
                        <ws:MenuItem Header="File">
                            <ws:MenuItem Command="{Binding SaveChartCommand}" Header="Save" />
                        </ws:MenuItem>
                        <ws:MenuItem Header="Debugging">
                            <ws:MenuItem Command="{Binding LoadDemoChartCommand}" Header="Load demo chart" />
                        </ws:MenuItem>
                    </ws:Menu>
                </StackPanel>
                <StackPanel
                    Margin="4"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <StackPanel.Resources>
                        <Style x:Key="CaptionButton" TargetType="{x:Type ws:Button}">
                            <Setter Property="Width" Value="28" />
                            <Setter Property="Height" Value="26" />
                            <Setter Property="Margin" Value="1,0,0,0" />
                            <Setter Property="CornerRadius" Value="4" />
                            <Setter Property="BorderThickness" Value="1" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                            <Setter Property="HoverBorderBrush" Value="#3d3d3d" />
                            <Setter Property="PressedBorderBrush" Value="Transparent" />
                            <Setter Property="Background" Value="#2e2e2e" />
                            <Setter Property="HoverBackground" Value="#3d3d3d" />
                            <Setter Property="PressedBackground" Value="#4f4f4f" />
                            <Setter Property="Foreground" Value="#b2b2b2" />
                            <Setter Property="Foreground" Value="#b2b2b2" />
                            <Setter Property="HoverForeground" Value="#fafafa" />
                        </Style>
                    </StackPanel.Resources>
                    <ws:Button
                        ws:WindowOption.IsMinimumButton="True"
                        Command="{Binding MinimizeSelfCommand}"
                        Content="-"
                        Style="{StaticResource CaptionButton}" />
                    <ws:Button
                        ws:WindowOption.IsMaximumButton="True"
                        Command="{Binding MaximizeRestoreSelfCommand}"
                        Content="+"
                        Style="{StaticResource CaptionButton}" />
                    <ws:Button
                        ws:WindowOption.IsCloseButton="True"
                        Command="{Binding CloseSelfCommand}"
                        Content="x"
                        HoverBackground="#e81123"
                        HoverBorderBrush="#e81123"
                        Style="{StaticResource CaptionButton}" />
                </StackPanel>
            </Grid>
            <Grid Margin="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="2.8*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <comp:TabPane Header="Properties">
                    <Grid>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border BorderBrush="#CCCCCC" BorderThickness="1">

                                <Canvas
                                    x:Name="GraphCanvas"
                                    Width="200"
                                    Height="200"
                                    Background="#414141"
                                    ClipToBounds="False">

                                    <Path
                                        x:Name="CurvePath"
                                        Stroke="Red"
                                        StrokeThickness="2" />

                                    <Line
                                        x:Name="Line1"
                                        Stroke="Gray"
                                        StrokeDashArray="4 2" />
                                    <Line
                                        x:Name="Line2"
                                        Stroke="Gray"
                                        StrokeDashArray="4 2" />

                                    <Ellipse
                                        x:Name="Thumb1"
                                        Width="14"
                                        Height="14"
                                        Cursor="Hand"
                                        Fill="#007ACC"
                                        MouseLeftButtonDown="Thumb_MouseDown"
                                        MouseLeftButtonUp="Thumb_MouseUp"
                                        MouseMove="Thumb_MouseMove" />

                                    <Ellipse
                                        x:Name="Thumb2"
                                        Width="14"
                                        Height="14"
                                        Cursor="Hand"
                                        Fill="#007ACC"
                                        MouseLeftButtonDown="Thumb_MouseDown"
                                        MouseLeftButtonUp="Thumb_MouseUp"
                                        MouseMove="Thumb_MouseMove" />

                                </Canvas>
                            </Border>
                            <StackPanel Width="200" Margin="0,10,0,0">

                                <Grid
                                    Width="200"
                                    Height="25"
                                    Margin="0,10,0,0"
                                    HorizontalAlignment="Center">

                                    <TextBlock
                                        x:Name="DisplayBox"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontWeight="Bold"
                                        MouseLeftButtonDown="DisplayBox_MouseLeftButtonDown" />

                                    <TextBox
                                        x:Name="InputBox"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        KeyDown="InputBox_KeyDown"
                                        LostFocus="InputBox_LostFocus"
                                        Visibility="Hidden" />
                                </Grid>

                            </StackPanel>
                        </StackPanel>

                    </Grid>
                </comp:TabPane>

                <comp:TabPane
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Header="Timeline">
                    <comp:ChartTimeline />
                </comp:TabPane>

                <comp:TabPane
                    Grid.Row="1"
                    Grid.Column="2"
                    Header="Project">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ws:Button Command="{Binding ImportMusicCommand}" Content="Import" />
                        </StackPanel>
                    </StackPanel>
                </comp:TabPane>

                <DockPanel Grid.Row="0" Grid.Column="1">
                    <StackPanel
                        HorizontalAlignment="Center"
                        DockPanel.Dock="Bottom"
                        Orientation="Horizontal">
                        <ws:Button Command="{Binding PlayPauseChartRenderingCommand}" Content="Play/Pause" />
                        <ws:Button Command="{Binding StopChartRenderingCommand}" Content="Stop" />
                    </StackPanel>
                    <comp:ChartRenderer
                        x:Name="chartRenderer"
                        Chart="{Binding ProjectManager.EditingProject.Chart}"
                        ClipToBounds="True" />
                </DockPanel>
            </Grid>
        </DockPanel>
    </ws:WindowContentAdapter>
</Window>
