<Window x:Class="Axphi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Axphi"
        xmlns:comp="clr-namespace:Axphi.Components"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        d:DataContext="{d:DesignInstance Type=local:MainWindow,IsDesignTimeCreatable=False}">
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="Save"
                          Command="{Binding SaveChartCommand}"/>
            </MenuItem>
            <MenuItem Header="Debugging">
                <MenuItem Header="Load demo chart"
                          Command="{Binding LoadDemoChartCommand}"/>
            </MenuItem>
        </Menu>
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button Content="Play/Pause"
                        Command="{Binding PlayPauseChartRenderingCommand}"/>
                <Button Content="Stop"
                        Command="{Binding StopChartRenderingCommand}"/>
            </StackPanel>
            <comp:ChartRenderer x:Name="chartRenderer"
                                Chart="{Binding ProjectManager.EditingProject.Chart}"
                                ClipToBounds="True"/>
        </DockPanel>
    </DockPanel>
</Window>
