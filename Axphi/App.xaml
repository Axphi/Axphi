<Application x:Class="Axphi.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ws="https://schemas.elecho.dev/wpfsuite"
             xmlns:comp="clr-namespace:Axphi.Components"
             xmlns:local="clr-namespace:Axphi">
    <Application.Resources>
        <Style TargetType="{x:Type ws:Menu}">
            <Setter Property="Background" Value="#1f1f1f"/>
            <Setter Property="Foreground" Value="#d6d6d6"/>
        </Style>
        <Style TargetType="{x:Type ws:MenuItem}">
            <Setter Property="Background" Value="#1f1f1f"/>
            <Setter Property="Foreground" Value="#d6d6d6"/>
            <Setter Property="PopupBackground" Value="#2e2e2e"/>
            <Setter Property="PopupBorderThickness" Value="0"/>
        </Style>

        <Style TargetType="{x:Type ws:Button}">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="4 3"/>
            <Setter Property="Foreground" Value="#cacaca"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HoverBorderBrush" Value="#3d3d3d"/>
            <Setter Property="PressedBorderBrush" Value="#4f4f4f"/>
            <Setter Property="Background" Value="#2e2e2e"/>
            <Setter Property="HoverBackground" Value="#3d3d3d"/>
            <Setter Property="PressedBackground" Value="#4f4f4f"/>
        </Style>

        <Style TargetType="{x:Type ws:ToggleButton}">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="4 3"/>
            <Setter Property="Foreground" Value="#cacaca"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HoverBorderBrush" Value="#3d3d3d"/>
            <Setter Property="PressedBorderBrush" Value="#4f4f4f"/>
            <Setter Property="Background" Value="#2e2e2e"/>
            <Setter Property="HoverBackground" Value="#3d3d3d"/>
            <Setter Property="PressedBackground" Value="#4f4f4f"/>
            <Setter Property="CheckedBackground" Value="#5f5f5f"/>
        </Style>
    </Application.Resources>
</Application>
