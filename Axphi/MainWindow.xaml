<Window
    x:Class="Axphi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:comp="clr-namespace:Axphi.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Axphi"
    xmlns:mainWinComp="clr-namespace:Axphi.WindowsComponents.MainWindow"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ws="https://schemas.elecho.dev/wpfsuite"
    Title="MainWindow"
    Width="1200"
    Height="650"
    d:DataContext="{d:DesignInstance Type=local:MainWindow,
                                     IsDesignTimeCreatable=False}"
    ws:WindowOption.IsCaptionMenuVisible="False"
    Background="#1f1f1f"
    Foreground="#d6d6d6"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome />
    </WindowChrome.WindowChrome>

    <ws:WindowContentAdapter>
        <DockPanel>
            <mainWinComp:TitleBar DockPanel.Dock="Top" />
            <Grid Margin="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="2.8*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <comp:TabPane
                    Grid.Row="0"
                    Grid.Column="0"
                    Header="Flow">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <comp:BezierCurveEditor
                                X1="{Binding BezierViewModel.X1, Mode=TwoWay}"
                                X2="{Binding BezierViewModel.X2, Mode=TwoWay}"
                                Y1="{Binding BezierViewModel.Y1, Mode=TwoWay}"
                                Y2="{Binding BezierViewModel.Y2, Mode=TwoWay}" />
                            <StackPanel
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.X1}" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.Y1}" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.X2}" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.00"
                                    Value="{Binding BezierViewModel.Y2}" />
                            </StackPanel>
                        </StackPanel>

                    </Grid>
                </comp:TabPane>

                <comp:TabPane Grid.Row="1" Grid.Column="0">

                    <comp:TabPane.Header>
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" Text="Line" />

                            <ws:Button
                                Margin="10,0,0,0"
                                Padding="8,0"
                                Command="{Binding Timeline.AddJudgementLineCommand}"
                                Content="+"
                                ToolTip="添加判定线图层" />
                        </StackPanel>
                    </comp:TabPane.Header>

                    <ScrollViewer Margin="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Timeline.CurrentChart.JudgementLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Height="40"
                                        Margin="0,0,0,2"
                                        Background="#2d2d2d"
                                        BorderBrush="#444"
                                        BorderThickness="0,0,0,1">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="4" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Rectangle Grid.Column="0" Fill="#FFD700" />

                                            <TextBlock
                                                Grid.Column="1"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                Foreground="#d6d6d6"
                                                Text="判定线图层" />
                                        </Grid>

                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                </comp:TabPane>

                <comp:TabPane
                    Grid.Row="1"
                    Grid.Column="1"
                    Header="Timeline">
                    <comp:ChartTimeline />
                </comp:TabPane>
                <comp:TabPane
                    Grid.Row="1"
                    Grid.Column="2"
                    Header="Project">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ws:Button Command="{Binding FileActions.ImportMusicCommand}" Content="Import" />
                        </StackPanel>
                    </StackPanel>
                </comp:TabPane>

                <DockPanel Grid.Row="0" Grid.Column="1">

                    <mainWinComp:ChartDisplay x:Name="MainChartDisplay" />

                </DockPanel>
            </Grid>
        </DockPanel>
    </ws:WindowContentAdapter>
</Window>
