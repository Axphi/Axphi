<UserControl x:Class="Axphi.Views.AudioTrackControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Axphi.Views"
             xmlns:comp="clr-namespace:Axphi.Components"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             mc:Ignorable="d"
             d:DesignHeight="80" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{DynamicResource TimelineLeftPanelWidth}" MinWidth="180" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="2.8*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Margin="0,0,2,2" Background="#2A2A2A" BorderBrush="#444" BorderThickness="0,0,0,1" VerticalAlignment="Top">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#2A2A2A" />
                    <Setter Property="BorderBrush" Value="#444" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLayerSelected}" Value="True">
                            <Setter Property="Background" Value="#25352A" />
                            <Setter Property="BorderBrush" Value="#4DAE6A" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel x:Name="AudioLayerPanel">
                <Grid Height="20" comp:LayerPointerInteraction.Enable="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Rectangle Grid.Column="0" Fill="#28E857" />
                    <TextBlock Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#28E857" Text="♫" FontSize="14" />

                    <CheckBox Grid.Column="2" IsChecked="{Binding IsExpanded}" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <CheckBox.Template>
                            <ControlTemplate TargetType="CheckBox">
                                <Grid Background="Transparent" Width="16" Height="16" Cursor="Hand">
                                    <Path x:Name="Arrow" Data="M 4,4 L 10,10 L 16,4" Stroke="#888" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="False">
                                        <Setter TargetName="Arrow" Property="Data" Value="M 6,2 L 12,8 L 6,14" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </CheckBox.Template>
                    </CheckBox>

                    <primitives:ToggleButton Grid.Column="3"
                                              Width="14"
                                              Height="14"
                                              Margin="2,0,0,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Cursor="Hand"
                                              IsChecked="{Binding IsDragLocked, Mode=TwoWay}"
                                              ToolTip="锁定音频图层拖拽">
                        <primitives:ToggleButton.Template>
                            <ControlTemplate TargetType="primitives:ToggleButton">
                                <Border x:Name="LockBox"
                                        Width="14"
                                        Height="14"
                                        CornerRadius="3"
                                        Background="#151515"
                                        BorderBrush="#454545"
                                        BorderThickness="1">
                                    <TextBlock x:Name="LockMark"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#E8E8E8"
                                               FontFamily="Consolas"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Text="×"
                                               Visibility="Collapsed" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="LockBox" Property="Background" Value="#202020" />
                                        <Setter TargetName="LockBox" Property="BorderBrush" Value="#6A6A6A" />
                                        <Setter TargetName="LockMark" Property="Visibility" Value="Visible" />
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="LockBox" Property="BorderBrush" Value="#7A7A7A" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </primitives:ToggleButton.Template>
                    </primitives:ToggleButton>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="5,0,0,0" VerticalAlignment="Center">
                        <TextBlock Foreground="#d6d6d6" Text="Audio (BGM)" FontWeight="Bold" />
                        <TextBlock Foreground="#888" Text="{Binding AudioDurationSeconds, StringFormat=' ({0:F1}s)'}" Margin="5,0,0,0" />
                    </StackPanel>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Background" Value="Transparent" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLayerSelected}" Value="True">
                                    <Setter Property="Background" Value="#1E4A2A" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                </Grid>

                <Grid Height="60">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>

                    <StackPanel Orientation="Horizontal" Margin="25,0,0,0" VerticalAlignment="Center">
                        <TextBlock Foreground="#888" Text="Volume: " VerticalAlignment="Center" Margin="0,0,5,0" />
                        <comp:DraggableValueBox Value="{Binding AudioVolume}" DragSpeed="1" NumberFormat="0'%'" Width="50" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="TrackScrollViewer"
                      Grid.Column="2" HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      comp:HorizontalScrollSyncInteraction.Enable="True"
                      comp:HorizontalScrollSyncInteraction.Timeline="{Binding Timeline}"
                      comp:MouseWheelPassthroughInteraction.Enable="True">

            <Border Margin="0,0,0,2" Background="#1e1e1e" BorderBrush="#444" BorderThickness="0,0,0,1" VerticalAlignment="Top">
                <Canvas Margin="8,0,0,0" Width="{Binding Timeline.TotalPixelWidth}" HorizontalAlignment="Left">
                    <Canvas.Style>
                        <Style TargetType="Canvas">
                            <Setter Property="Height" Value="80" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                    <Setter Property="Height" Value="20" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Canvas.Style>

                              <Thumb Canvas.Left="{Binding LayerPixelXOffset}"
                              comp:LayerPointerInteraction.Enable="True"
                              comp:TimelineThumbInteraction.EnableDrag="True">
                        <Thumb.Style>
                            <Style TargetType="Thumb">
                                <Setter Property="Cursor" Value="SizeWE" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDragLocked}" Value="True">
                                        <Setter Property="Cursor" Value="Arrow" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Thumb.Style>
                        <Thumb.Template>
                            <ControlTemplate TargetType="Thumb">
                                <Grid Width="{Binding LayerPixelWidth}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="20" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Rectangle Grid.Row="0" x:Name="LayerRect" Fill="#28E857" Opacity="0.5" />

                                    <Border Grid.Row="1" x:Name="WaveformBorder" Height="60" Background="#1128E857" BorderBrush="#2228E857" BorderThickness="1,0,1,1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <comp:WaveformRenderer Peaks="{Binding WaveformPeaks}" Volume="{Binding AudioVolume}" Margin="0,2" />


                                    </Border>
                                </Grid>

                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsLayerSelected}" Value="True">
                                        <Setter TargetName="LayerRect" Property="Opacity" Value="0.95" />
                                        <Setter TargetName="LayerRect" Property="Stroke" Value="#FFFFFF" />
                                        <Setter TargetName="LayerRect" Property="StrokeThickness" Value="1.5" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDragLocked}" Value="True">
                                        <Setter TargetName="LayerRect" Property="Opacity" Value="0.22" />
                                        <Setter TargetName="WaveformBorder" Property="Opacity" Value="0.45" />
                                    </DataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsDragLocked}" Value="False" />
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="LayerRect" Property="Opacity" Value="0.8" />
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsDragLocked}" Value="True" />
                                            <Condition Binding="{Binding IsLayerSelected}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="LayerRect" Property="Opacity" Value="0.4" />
                                        <Setter TargetName="LayerRect" Property="Stroke" Value="#A0A0A0" />
                                    </MultiDataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Canvas>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>