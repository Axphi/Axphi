<UserControl x:Class="Axphi.Components.DraggableOptionBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:EleCho.WpfSuite.ValueConverters;assembly=EleCho.WpfSuite.ValueConverters"
             mc:Ignorable="d"
             d:DesignHeight="30" d:DesignWidth="100"
             Name="Root">

    <UserControl.Resources>
        <conv:ValueConverterGroup x:Key="InvertBooleanToVisibilityConverter">
            <conv:InvertBooleanConverter />
            <conv:BooleanToVisibilityConverter />
        </conv:ValueConverterGroup>
    </UserControl.Resources>

    <Grid Name="Container" Background="Transparent"
          Cursor="SizeWE"
          MouseLeftButtonDown="OnMouseDown"
          MouseLeftButtonUp="OnMouseUp"
          MouseMove="OnMouseMove">
        <Border x:Name="HoverBorder"
                Background="Transparent"
                CornerRadius="2"
                Padding="2,1">
            <TextBlock Text="{Binding Value, ElementName=Root}"
                       Foreground="#007ACC"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>

        <Popup x:Name="OptionsPopup"
               StaysOpen="False"
               PlacementTarget="{Binding ElementName=Container}"
               Placement="Bottom"
               AllowsTransparency="True">
            <Border Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    CornerRadius="3"
                    Padding="2"
                    Margin="0,2,0,0">
                <ItemsControl ItemsSource="{Binding Options, ElementName=Root}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Click="OptionButton_Click"
                                    Cursor="Hand"
                                    Foreground="White"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BgBorder" CornerRadius="2" Background="Transparent">
                                            <ContentPresenter Margin="12,6" HorizontalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BgBorder" Property="Background" Value="#33FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Popup>

        <Grid.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetName="HoverBorder"
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="#33FFFFFF" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetName="HoverBorder"
                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                        To="Transparent" Duration="0:0:0.1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
    </Grid>
</UserControl>