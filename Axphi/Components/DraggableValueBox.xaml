<UserControl x:Class="Axphi.Components.DraggableValueBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="300">

    <UserControl.Resources>
        <DataTemplate x:Key="NumberItemTemplate">
            <Grid Background="Transparent" 
                  Cursor="SizeWE" 
                  MouseLeftButtonDown="Number_MouseDown"
                  MouseLeftButtonUp="Number_MouseUp"
                  MouseMove="Number_MouseMove"
                  Tag="{Binding}">
                <Border x:Name="HoverBorder" 
                        Background="Transparent" 
                        CornerRadius="2" 
                        Padding="2, 1">
                    <TextBlock Text="{Binding DisplayText}" 
                               Foreground="#007ACC" 
                               FontWeight="Bold"/>
                </Border>

                <TextBox x:Name="EditBox"
                         Text="{Binding Value, StringFormat=N2}" 
                         Visibility="Collapsed"
                         MinWidth="40"
                         Padding="0"
                         Margin="0"
                         BorderThickness="1"
                         Foreground="White" 
                         Background="#55555555"
                         HorizontalContentAlignment="Center"
                         FontWeight="Bold"
                         KeyDown="EditBox_KeyDown"
                         LostFocus="EditBox_LostFocus"
                         Loaded="EditBox_Loaded"/>

                <Grid.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="HoverBorder" 
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="#33FFFFFF" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="HoverBorder" 
                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                To="Transparent" Duration="0:0:0.1"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Grid.Triggers>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TextItemTemplate">
            <TextBlock Text="{Binding DisplayText}" 
                       Foreground="Gray" 
                       VerticalAlignment="Center" 
                       Margin="2,0"/>
        </DataTemplate>

        <local:ChunkTemplateSelector x:Key="ChunkSelector"
                                     NumberTemplate="{StaticResource NumberItemTemplate}"
                                     TextTemplate="{StaticResource TextItemTemplate}"
                                     xmlns:local="clr-namespace:Axphi.Components"/>
    </UserControl.Resources>

    <ItemsControl x:Name="MainItemsControl" 
                  ItemTemplateSelector="{StaticResource ChunkSelector}"
                  FocusVisualStyle="{x:Null}">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
    </ItemsControl>
</UserControl>