<Window
    x:Class="Axphi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:comp="clr-namespace:Axphi.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Axphi"
    xmlns:mainWinComp="clr-namespace:Axphi.WindowsComponents.MainWindow"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ws="https://schemas.elecho.dev/wpfsuite"
    Title="MainWindow"
    Width="1200"
    Height="650"
    d:DataContext="{d:DesignInstance Type=local:MainWindow,
                                     IsDesignTimeCreatable=False}"
    ws:WindowOption.IsCaptionMenuVisible="False"
    Background="#1f1f1f"
    Foreground="#d6d6d6"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome />
    </WindowChrome.WindowChrome>

    <ws:WindowContentAdapter>
        <DockPanel>
            <mainWinComp:TitleBar DockPanel.Dock="Top" />
            <Grid Margin="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="2.8*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <comp:TabPane
                    Grid.Row="0"
                    Grid.Column="0"
                    Header="Flow">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border BorderBrush="#CCCCCC" BorderThickness="1">

                                <Canvas
                                    x:Name="GraphCanvas"
                                    Width="200"
                                    Height="200"
                                    Background="#414141"
                                    ClipToBounds="False">

                                    <Path
                                        x:Name="CurvePath"
                                        Stroke="Red"
                                        StrokeThickness="2" />

                                    <Line
                                        x:Name="Line1"
                                        Stroke="Gray"
                                        StrokeDashArray="4 2" />
                                    <Line
                                        x:Name="Line2"
                                        Stroke="Gray"
                                        StrokeDashArray="4 2" />

                                    <Ellipse
                                        x:Name="Thumb1"
                                        Width="14"
                                        Height="14"
                                        Cursor="Hand"
                                        Fill="#007ACC"
                                        MouseLeftButtonDown="Thumb_MouseDown"
                                        MouseLeftButtonUp="Thumb_MouseUp"
                                        MouseMove="Thumb_MouseMove" />

                                    <Ellipse
                                        x:Name="Thumb2"
                                        Width="14"
                                        Height="14"
                                        Cursor="Hand"
                                        Fill="#007ACC"
                                        MouseLeftButtonDown="Thumb_MouseDown"
                                        MouseLeftButtonUp="Thumb_MouseUp"
                                        MouseMove="Thumb_MouseMove" />

                                </Canvas>
                            </Border>
                            <StackPanel
                                Margin="0,10,0,0"
                                HorizontalAlignment="Center"
                                Orientation="Horizontal">
                                <comp:DraggableValueBox
                                    Height="30"
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.0"
                                    Value="{Binding ViewModel.X1}" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox
                                    Height="30"
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.0"
                                    Value="{Binding ViewModel.Y1}" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox
                                    Height="30"
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.0"
                                    Value="{Binding ViewModel.X2}" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox
                                    Height="30"
                                    DragSpeed="0.01"
                                    Maximum="123"
                                    NumberFormat="0.0"
                                    Value="{Binding ViewModel.Y2}" />
                            </StackPanel>
                        </StackPanel>

                    </Grid>
                </comp:TabPane>

                <comp:TabPane
                    Grid.Row="1"
                    Grid.Column="0"
                    Header="Line">
                    <comp:ChartTimeline />
                </comp:TabPane>

                <comp:TabPane
                    Grid.Row="1"
                    Grid.Column="1"
                    Header="Timeline" />
                <comp:TabPane
                    Grid.Row="1"
                    Grid.Column="2"
                    Header="Project">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ws:Button Command="{Binding ImportMusicCommand}" Content="Import" />
                        </StackPanel>
                    </StackPanel>
                </comp:TabPane>

                <DockPanel Grid.Row="0" Grid.Column="1">

                    <mainWinComp:ChartDisplay x:Name="MainChartDisplay" />

                </DockPanel>
            </Grid>
        </DockPanel>
    </ws:WindowContentAdapter>
</Window>
