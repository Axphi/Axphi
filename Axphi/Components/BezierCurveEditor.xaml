<UserControl x:Class="Axphi.Components.BezierCurveEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Axphi.Components"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Border BorderBrush="#CCCCCC" BorderThickness="1">
            <Canvas
                x:Name="GraphCanvas"
                Width="200"
                Height="200"
                Background="#414141"
                ClipToBounds="False"
                PreviewMouseLeftButtonDown="GraphCanvas_PreviewMouseLeftButtonDown"
                PreviewMouseMove="GraphCanvas_PreviewMouseMove"
                PreviewMouseLeftButtonUp="GraphCanvas_PreviewMouseLeftButtonUp">

                <Path
                    x:Name="GridPath"
                    Stroke="#66FFFFFF"
                    StrokeThickness="0.5"
                    SnapsToDevicePixels="True" />

                <Path
                    x:Name="CurvePath"
                    Stroke="Red"
                    StrokeThickness="2" />

                <Line
                    x:Name="Line1"
                    Stroke="Gray"
                    StrokeDashArray="4 2" />
                <Line
                    x:Name="Line2"
                    Stroke="Gray"
                    StrokeDashArray="4 2" />

                <Ellipse
                    x:Name="Thumb1"
                    Width="14"
                    Height="14"
                    Cursor="Hand"
                    Fill="#007ACC"
                    MouseLeftButtonDown="Thumb_MouseDown"
                    MouseLeftButtonUp="Thumb_MouseUp"
                    MouseMove="Thumb_MouseMove" />
                    <!-- 这三个事件不会被触发 -->

                    <Ellipse
                    x:Name="Thumb2"
                    Width="14"
                    Height="14"
                    Cursor="Hand"
                    Fill="#007ACC"
                    MouseLeftButtonDown="Thumb_MouseDown"
                    MouseLeftButtonUp="Thumb_MouseUp"
                    MouseMove="Thumb_MouseMove" />

            </Canvas>
        </Border>
    </Grid>
</UserControl>
