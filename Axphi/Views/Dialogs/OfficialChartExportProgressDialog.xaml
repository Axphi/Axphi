<Window x:Class="Axphi.Views.Dialogs.OfficialChartExportProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="导出官谱"
        Width="380"
        Height="210"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <Window.Resources>
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="12" />
            <Setter Property="Foreground" Value="#d9a441" />
            <Setter Property="Background" Value="#2b2b2b" />
            <Setter Property="BorderBrush" Value="#4a4a4a" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Border Background="#1f1f1f"
            BorderBrush="#3d3d3d"
            BorderThickness="1"
            CornerRadius="10"
            Padding="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleTextBlock"
                       Text="导出官谱"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#f2f2f2" />

            <StackPanel x:Name="SetupPanel"
                        Grid.Row="1"
                        Margin="0,14,0,12">
                <CheckBox x:Name="CalculateFloorPositionCheckBox"
                          Foreground="#d6d6d6"
                          Content="计算 floorPosition"
                          IsChecked="False" />
            </StackPanel>

            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="2"
                       Margin="0,0,0,10"
                       Text="准备导出官谱..."
                       Foreground="#d6d6d6"
                       TextTrimming="CharacterEllipsis" />

            <Grid x:Name="ProgressPanel"
                  Grid.Row="3">
                <ProgressBar x:Name="ProgressBar"
                             Minimum="0"
                             Maximum="100"
                             Value="0" />
                <TextBlock x:Name="PercentTextBlock"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,-24,0,0"
                           Foreground="#9f9f9f"
                           Text="0%" />
            </Grid>

            <Button x:Name="RenderButton"
                    Grid.Row="3"
                    HorizontalAlignment="Right"
                    MinWidth="92"
                    Padding="14,5"
                    Margin="0,14,0,0"
                    Background="#d9a441"
                    Foreground="#111111"
                    BorderBrush="#e0b45f"
                    Click="RenderButton_Click"
                    Content="渲染" />
        </Grid>
    </Border>
</Window>