<Window
    x:Class="Axphi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:comp="clr-namespace:Axphi.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Axphi"
    xmlns:mainWinComp="clr-namespace:Axphi.WindowsComponents.MainWindow"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ws="https://schemas.elecho.dev/wpfsuite"
    Title="MainWindow"
    Width="1200"
    Height="650"
    d:DataContext="{d:DesignInstance Type=local:MainWindow,
                                     IsDesignTimeCreatable=False}"
    ws:WindowOption.IsCaptionMenuVisible="False"
    Background="#1f1f1f"
    Foreground="#d6d6d6"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome />
    </WindowChrome.WindowChrome>

    <ws:WindowContentAdapter>
        <DockPanel>
            <mainWinComp:TitleBar DockPanel.Dock="Top" />
            <Grid Margin="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="1*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="2.8*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <comp:TabPane
                    Grid.Row="0"
                    Grid.Column="0"
                    Header="Flow">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <comp:BezierCurveEditor 
                                X1="{Binding BezierViewModel.X1, Mode=TwoWay}"
                                Y1="{Binding BezierViewModel.Y1, Mode=TwoWay}"
                                X2="{Binding BezierViewModel.X2, Mode=TwoWay}"
                                Y2="{Binding BezierViewModel.Y2, Mode=TwoWay}" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10 0 0">
                                <comp:DraggableValueBox Value="{Binding BezierViewModel.X1}" DragSpeed="0.01" NumberFormat="0.00" Maximum="123" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox Value="{Binding BezierViewModel.Y1}" DragSpeed="0.01" NumberFormat="0.00" Maximum="123" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox Value="{Binding BezierViewModel.X2}" DragSpeed="0.01" NumberFormat="0.00" Maximum="123" />
                                <TextBlock Text=", " />
                                <comp:DraggableValueBox Value="{Binding BezierViewModel.Y2}" DragSpeed="0.01" NumberFormat="0.00" Maximum="123" />
                            </StackPanel>
                        </StackPanel>

                    </Grid>
                </comp:TabPane>

                <comp:TabPane
                    Grid.Row="1"
                    Grid.Column="0">

                    <comp:TabPane.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Line" VerticalAlignment="Center" />

                            <ws:Button Content="+" 
                                       Margin="10,0,0,0" 
                                       Padding="8,0"
                                       Command="{Binding AddJudgementLineCommand}" 
                                       ToolTip="添加判定线图层"/>
                        </StackPanel>
                    </comp:TabPane.Header>

                    <comp:ChartTimeline />

                </comp:TabPane>

                <comp:TabPane
                    Grid.Row="1"
                    Grid.Column="1"
                    Header="Timeline" />
                <comp:TabPane
                    Grid.Row="1"
                    Grid.Column="2"
                    Header="Project">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ws:Button Command="{Binding FileActions.ImportMusicCommand}" Content="Import" />
                        </StackPanel>
                    </StackPanel>
                </comp:TabPane>

                <DockPanel Grid.Row="0" Grid.Column="1">

                    <mainWinComp:ChartDisplay x:Name="MainChartDisplay" />

                </DockPanel>
            </Grid>
        </DockPanel>
    </ws:WindowContentAdapter>
</Window>
